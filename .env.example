# Vigil — environment variables
# Copy to .env and fill in. Backend reads via python-dotenv.

# ─── BigQuery (already wired via gcloud ADC; no key in .env needed) ────
GCP_PROJECT_ID=agency2026ot-kova-0429
BQ_DATA_PROJECT=agency2026ot-data-1776775157

# ─── Anthropic (REQUIRED for classifier + briefing memo) ───────────────
# Without this, risk score still works but the "why flagged" panel is
# replaced with a deterministic auto-summary.
ANTHROPIC_API_KEY=

# Use the Sonnet 4 model the spec calls for. Override if needed.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── External adverse-media + sanctions sources ────────────────────────
# Each is independently optional; missing keys -> empty panel, no crash.

OPENSANCTIONS_API_KEY=
TAVILY_API_KEY=
CANLII_API_KEY=

# ─── Backend / frontend wiring ─────────────────────────────────────────
BACKEND_PORT=8000
NEXT_PUBLIC_API_BASE=http://localhost:8000
